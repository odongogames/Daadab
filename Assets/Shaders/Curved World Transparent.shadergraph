{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "84ec1eff17e54062aedf2a4df3983d95",
    "m_Title": "Vec2 + Tiling",
    "m_Content": "The tiling property needs to have the same value for X & Y which is why it's connected to a vec2 node. The float is only connected to the Y bcoz it's only meant to tile in one direction. (Making sure that neither X or Y is zero otherwise no tiling)",
